# ==============================================
# GRIND CAMP - Environment Variables Configuration
# ==============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control!

# ------------------------------------------
# ADMIN AUTHENTICATION
# ------------------------------------------
# Generate a hash for your admin password using this command:
# node -e "const p='YOUR_PASSWORD';const s='grind_salt_2026';require('crypto').subtle.digest('SHA-256',new TextEncoder().encode(p+s)).then(h=>console.log(Array.from(new Uint8Array(h)).map(b=>b.toString(16).padStart(2,'0')).join('')))"
REACT_APP_ADMIN_HASH=your_sha256_hash_here

# ------------------------------------------
# GEMINI API (Optional - Voice Chat)
# ------------------------------------------
# WARNING: This key will be exposed in the browser!
# Only enable in development/staging environments
# For production, implement a backend proxy
GEMINI_API_KEY=AIzaSyAy17m17tZTMvUdbk_y7SxIzUcSWMs8HGw

# ------------------------------------------
# CLOUD FUNCTION CONFIGURATION
# ------------------------------------------
# URL de la Cloud Function pour l'envoi d'emails
# À mettre à jour après déploiement de la fonction
VITE_CLOUD_FUNCTION_URL=https://europe-west1-adp-413110.cloudfunctions.net/sendRegistrationEmail

# Email expéditeur (avec domain-wide delegation)
FROM_EMAIL=amani.bestoftours.co.uk

# Admin email recipients (comma-separated)
ADMIN_EMAILS=grindcamp84@gmail.com,yacine@bestoftours.co.uk

# Service Account (NE PAS mettre ici, utiliser Secret Manager dans GCP)
# Le service account est stocké dans : services/adp-413110-176b452e6fb2.json
# Et déployé via Secret Manager pour la Cloud Function

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=https://grindcamp.fr,https://www.grindcamp.fr,http://localhost:3000

